---
import BaseLayout from "./BaseLayout.astro";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
import { t, localePath } from "../i18n/utils";
import type { Locale } from "../i18n/utils";

interface Props {
  title: string;
  company: string;
  period: string;
  role: string;
  tags: string[];
  github?: string;
  demo?: string;
  sideProject?: boolean;
  claudeCode?: boolean;
  education?: boolean;
  locale?: Locale;
}

const {
  title,
  company,
  period,
  role,
  tags,
  github,
  demo,
  sideProject,
  claudeCode,
  education,
  locale = "ko",
} = Astro.props;

const factLabels = {
  ko: {
    period: "기간",
    type: "분류",
    role: "역할",
    company: "실무 프로젝트",
    education: "교육 프로젝트",
    side: "개인 프로젝트",
  },
  en: {
    period: "Period",
    type: "Type",
    role: "Role",
    company: "Company",
    education: "Education",
    side: "Side Project",
  },
  ja: {
    period: "期間",
    type: "区分",
    role: "役割",
    company: "実務プロジェクト",
    education: "教育プロジェクト",
    side: "個人プロジェクト",
  },
} satisfies Record<Locale, Record<string, string>>;

const activeFactLabels = factLabels[locale];
const typeLabel = education ? activeFactLabels.education : sideProject ? activeFactLabels.side : activeFactLabels.company;
---

<BaseLayout title={`${title} | ${t("hero.name", locale)}`}>
  <Navbar locale={locale} />
  <main class="case-page">
    <section class="case-hero">
      <div class="case-shell">
        <a href={localePath("/projects", locale)} class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" class="icon-sm" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          {t("layout.backToMain", locale)}
        </a>

        <div class="case-hero-grid">
          <div class="case-title">
            <p class="case-kicker">{company}</p>
            <h1>{title}</h1>
            <p class="case-role">{role}</p>

            <div class="case-links" aria-label="Project links">
              {github && (
                <a href={github} target="_blank" rel="noopener noreferrer">
                  <svg xmlns="http://www.w3.org/2000/svg" class="icon-sm" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                  </svg>
                  GitHub
                </a>
              )}
              {demo && (
                <a href={demo} target="_blank" rel="noopener noreferrer">
                  <svg xmlns="http://www.w3.org/2000/svg" class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                    <polyline points="15 3 21 3 21 9" />
                    <line x1="10" y1="14" x2="21" y2="3" />
                  </svg>
                  Live
                </a>
              )}
            </div>
          </div>

          <aside class="case-facts" aria-label="Project facts">
            <dl>
              <div>
                <dt>{activeFactLabels.period}</dt>
                <dd>{period}</dd>
              </div>
              <div>
                <dt>{activeFactLabels.type}</dt>
                <dd>{typeLabel}</dd>
              </div>
              <div>
                <dt>{activeFactLabels.role}</dt>
                <dd>{role}</dd>
              </div>
            </dl>
            <div class="case-tags">
              {tags.map((tag) => <span>{tag}</span>)}
              {claudeCode && <span>Claude Code</span>}
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="case-body">
      <article class="prose-custom">
        <slot />
      </article>
    </section>
  </main>
  <Footer locale={locale} />
</BaseLayout>

<style>
  .case-page {
    min-height: 100vh;
  }

  .case-shell,
  .case-body {
    width: min(100% - 32px, 1120px);
    margin: 0 auto;
  }

  .case-hero {
    border-bottom: 1px solid var(--color-border);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.025), transparent 72%),
      var(--color-bg);
  }

  :global(html.light) .case-hero {
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.025), transparent 72%),
      var(--color-bg);
  }

  .case-shell {
    padding: 56px 0 46px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 42px;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    transition: color 160ms ease;
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .icon-sm {
    width: 16px;
    height: 16px;
    flex: 0 0 auto;
  }

  .case-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 56px;
    align-items: end;
  }

  .case-kicker {
    margin: 0 0 16px;
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .case-title h1 {
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 0.98;
    max-width: 780px;
  }

  .case-role {
    margin: 18px 0 0;
    max-width: 680px;
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.7;
  }

  .case-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 26px;
  }

  .case-links a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 36px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0 12px;
    color: var(--color-text);
    font-size: 0.8125rem;
    font-weight: 700;
    transition:
      border-color 160ms ease,
      color 160ms ease,
      background-color 160ms ease;
  }

  .case-links a:hover {
    border-color: color-mix(in srgb, var(--color-primary), transparent 45%);
    background: color-mix(in srgb, var(--color-primary), transparent 90%);
    color: var(--color-primary);
  }

  .case-facts {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 20px;
    background: color-mix(in srgb, var(--color-surface), transparent 38%);
  }

  .case-facts dl {
    display: grid;
    gap: 18px;
    margin: 0;
  }

  .case-facts dt {
    margin-bottom: 5px;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .case-facts dd {
    margin: 0;
    color: var(--color-text);
    font-size: 0.9375rem;
    line-height: 1.55;
  }

  .case-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 22px;
    padding-top: 18px;
    border-top: 1px solid var(--color-border);
  }

  .case-tags span {
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 5px 7px;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
  }

  .case-body {
    padding: 52px 0 92px;
  }

  .prose-custom {
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1.8;
    counter-reset: section-counter;
  }

  .prose-custom :global(.metric-strip) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 0;
    margin: 0 0 48px;
    padding: 18px 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .prose-custom :global(.metric-stat) {
    min-width: 0;
    padding: 0 22px;
  }

  .prose-custom :global(.metric-stat:first-child) {
    padding-left: 0;
  }

  .prose-custom :global(.metric-stat + .metric-stat) {
    border-left: 1px solid var(--color-border);
  }

  .prose-custom :global(.metric-stat .value) {
    display: block;
    color: var(--color-primary);
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 3vw, 2.05rem);
    font-weight: 800;
    line-height: 1.05;
  }

  .prose-custom :global(.metric-stat .label) {
    display: block;
    margin-top: 7px;
    color: var(--color-text-secondary);
    font-size: 0.8125rem;
    line-height: 1.4;
  }

  .prose-custom :global(h2) {
    counter-increment: section-counter;
    display: grid;
    grid-template-columns: 68px minmax(0, 1fr);
    gap: 18px;
    align-items: baseline;
    margin: 54px 0 18px;
    padding-top: 28px;
    border-top: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 2.4vw, 1.8rem);
    font-weight: 800;
    line-height: 1.25;
  }

  .prose-custom :global(h2:first-of-type) {
    margin-top: 0;
  }

  .prose-custom :global(h2::before) {
    content: "0" counter(section-counter);
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 700;
  }

  .prose-custom :global(h3) {
    margin: 32px 0 12px;
    color: var(--color-text);
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 750;
  }

  .prose-custom :global(p) {
    max-width: 820px;
    margin: 0 0 18px 86px;
    color: var(--color-text-secondary);
    line-height: 1.9;
  }

  .prose-custom :global(ul) {
    max-width: 860px;
    margin: 0 0 26px 86px;
    padding: 0;
    list-style: none;
  }

  .prose-custom :global(li) {
    position: relative;
    padding-left: 18px;
    color: var(--color-text-secondary);
    line-height: 1.82;
  }

  .prose-custom :global(li + li) {
    margin-top: 10px;
  }

  .prose-custom :global(li::before) {
    content: "";
    position: absolute;
    top: 0.82em;
    left: 0;
    width: 6px;
    height: 1px;
    background: var(--color-primary);
  }

  .prose-custom :global(strong) {
    color: var(--color-text);
    font-weight: 700;
  }

  .prose-custom :global(code) {
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 2px 5px;
    background: color-mix(in srgb, var(--color-surface), transparent 35%);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.875em;
  }

  .prose-custom :global(.highlight-box) {
    max-width: 900px;
    margin: 24px 0 34px 86px;
    border-left: 3px solid var(--color-primary);
    border-radius: 0 8px 8px 0;
    padding: 18px 20px;
    background: color-mix(in srgb, var(--color-primary), transparent 94%);
    color: var(--color-text-secondary);
    line-height: 1.85;
  }

  .prose-custom :global(.highlight-box strong) {
    color: var(--color-primary);
  }

  .prose-custom :global(.compare) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    max-width: 940px;
    margin: 0 0 28px 86px;
  }

  .prose-custom :global(.compare-item) {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 18px;
    background: color-mix(in srgb, var(--color-surface), transparent 46%);
  }

  .prose-custom :global(.compare-item .tag) {
    display: block;
    margin-bottom: 10px;
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .prose-custom :global(.compare-item.before .tag) {
    color: var(--color-text-secondary);
  }

  .prose-custom :global(.compare-item p) {
    margin: 0;
    max-width: none;
    font-size: 0.92rem;
    line-height: 1.72;
  }

  .prose-custom :global(.process-flow) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 10px;
    max-width: 940px;
    margin: 0 0 30px 86px;
  }

  .prose-custom :global(.process-step) {
    min-height: 92px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 16px;
    background: color-mix(in srgb, var(--color-surface), transparent 50%);
  }

  .prose-custom :global(.process-step .step-title) {
    color: var(--color-text);
    font-size: 0.95rem;
    font-weight: 800;
  }

  .prose-custom :global(.process-step .step-desc) {
    margin-top: 8px;
    color: var(--color-text-secondary);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .prose-custom :global(.process-arrow) {
    display: none;
  }

  .prose-custom :global(.bento-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 10px;
    max-width: 940px;
    margin: 0 0 30px 86px;
  }

  .prose-custom :global(.bento-item) {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 16px;
    background: transparent;
  }

  .prose-custom :global(.bento-label) {
    display: block;
    margin-bottom: 8px;
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .prose-custom :global(.bento-value) {
    color: var(--color-text-secondary);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .prose-custom :global(img) {
    display: block;
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-surface);
  }

  .prose-custom :global(.arch-block) {
    margin: 36px 0 52px;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 32px rgba(0, 0, 0, 0.07), 0 0 0 1px rgba(0,0,0,0.03);
  }

  :global(html.light) .prose-custom :global(.arch-block) {
    box-shadow: 0 2px 32px rgba(0, 0, 0, 0.10), 0 0 0 1px rgba(0,0,0,0.04);
  }

  .prose-custom :global(.arch-eyebrow) {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-primary), transparent 93%);
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .prose-custom :global(.arch-eyebrow::before) {
    content: "";
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    opacity: 0.7;
  }

  .prose-custom :global(.arch-img) {
    display: block;
    width: 100%;
    border: none !important;
    border-radius: 0 !important;
    background: #f8f9fa;
  }

  :global(html:not(.light)) .prose-custom :global(.arch-img) {
    filter: brightness(0.92) contrast(1.05);
  }

  .prose-custom :global(h2 + div[style*="display:grid"]) {
    margin-left: 86px;
  }

  @media (max-width: 900px) {
    .case-hero-grid {
      grid-template-columns: 1fr;
      gap: 32px;
      align-items: start;
    }

    .case-facts {
      max-width: 100%;
    }

    .prose-custom :global(.metric-strip) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .prose-custom :global(.metric-stat:nth-child(odd)) {
      padding-left: 0;
      border-left: 0;
    }
  }

  @media (max-width: 640px) {
    .case-shell,
    .case-body {
      width: min(100% - 28px, 1120px);
    }

    .case-shell {
      padding: 76px 0 34px;
    }

    .back-link {
      margin-bottom: 28px;
    }

    .case-title h1 {
      font-size: clamp(2rem, 11vw, 3.1rem);
      line-height: 1.04;
    }

    .case-facts {
      padding: 16px;
    }

    .case-body {
      padding-top: 36px;
    }

    .prose-custom :global(.metric-strip) {
      grid-template-columns: 1fr;
      padding: 0;
    }

    .prose-custom :global(.metric-stat) {
      padding: 16px 0;
    }

    .prose-custom :global(.metric-stat + .metric-stat) {
      border-top: 1px solid var(--color-border);
      border-left: 0;
    }

    .prose-custom :global(h2) {
      grid-template-columns: 44px minmax(0, 1fr);
      gap: 10px;
      margin-top: 44px;
    }

    .prose-custom :global(p),
    .prose-custom :global(ul),
    .prose-custom :global(.highlight-box),
    .prose-custom :global(.compare),
    .prose-custom :global(.process-flow),
    .prose-custom :global(.bento-grid),
    .prose-custom :global(h2 + div[style*="display:grid"]) {
      margin-left: 0;
    }

    .prose-custom :global(.compare) {
      grid-template-columns: 1fr;
    }
  }
</style>
